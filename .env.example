# PolyDev Coach Environment Variables
# Copy this file to .env and fill in your actual values

# Gradient AI Configuration
GRADIENT_API_KEY=your_gradient_api_key_here
GRADIENT_BASE_URL=https://bedrock-runtime.${AWS_REGION}.amazonaws.com

# Agent IDs (create agents in Gradient UI and paste IDs here)
ORCHESTRATOR_AGENT_ID=your_orchestrator_agent_id_here
ANALYZER_AGENT_ID=your_analyzer_agent_id_here
COACH_AGENT_ID=your_coach_agent_id_here
REFACTOR_AGENT_ID=your_refactor_agent_id_here
VALIDATOR_AGENT_ID=your_validator_agent_id_here
OPTIMIZER_AGENT_ID=your_optimizer_agent_id_here

# Application Configuration
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
MAX_CODE_LENGTH=15000
LOG_LEVEL=INFO
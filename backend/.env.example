# Gradient AI Configuration (Required)
GRADIENT_API_KEY=your_gradient_api_key_here
GRADIENT_BASE_URL=https://bedrock-runtime.${AWS_REGION}.amazonaws.com

# Agent IDs (Required - Create agents in Gradient UI first)
ANALYZER_AGENT_ID=your_analyzer_agent_id_here
COACH_AGENT_ID=your_coach_agent_id_here
REFACTOR_AGENT_ID=your_refactor_agent_id_here
VALIDATOR_AGENT_ID=your_validator_agent_id_here
OPTIMIZER_AGENT_ID=your_optimizer_agent_id_here

# App Configuration
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80
MAX_CODE_LENGTH=15000
LOG_LEVEL=INFO

# Database Configuration (Optional)
DATABASE_URL=sqlite:///./test.db

# Legacy variables (kept for compatibility)
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
GRADIENT_WORKSPACE_ID=your_workspace_id_here
GRADIENT_API_BASE=https://api.gradient.ai
FRONTEND_URL=http://localhost:3000
